/*.html
  Cache-Control: no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://*.thirdweb.com https://*.supabase.co wss://*.supabase.co; img-src 'self' data: https://*; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:;

/assets/*
  Cache-Control: public, max-age=31536000, immutable
