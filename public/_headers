/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com; connect-src 'self' https://*.thirdweb.com https://*.supabase.co; img-src 'self' data:; style-src 'self' 'unsafe-inline';

/assets/*
  Cache-Control: public, max-age=31536000, immutable
